---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildTitle } from "../../utils/seo";
import { createSupabaseServerClient } from "../../lib/supabase";
import {
  listEvents,
  createEvent,
  deleteEvent,
  formatEventDate,
} from "../../lib/events";

// SSR + protected. (ADR-011)
export const prerender = false;

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);

// Gate: must be signed in. RLS would block writes anyway, but redirecting gives
// a clean UX instead of a silent failure.
const {
  data: { user },
} = await supabase.auth.getUser();
if (!user) return Astro.redirect("/login");

let error: string | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const intent = String(form.get("intent") ?? "");

  try {
    if (intent === "create") {
      await createEvent(supabase, {
        title: String(form.get("title") ?? "").trim(),
        event_date: String(form.get("event_date") ?? ""),
        description: String(form.get("description") ?? "").trim(),
      });
    } else if (intent === "delete") {
      await deleteEvent(supabase, String(form.get("id") ?? ""));
    } else if (intent === "signout") {
      await supabase.auth.signOut();
      return Astro.redirect("/events");
    }
  } catch (e) {
    error = e instanceof Error ? e.message : "Something went wrong.";
  }

  // PRG pattern: redirect after a successful mutation to avoid resubmits.
  if (!error) return Astro.redirect("/admin/events");
}

const events = await listEvents(supabase);
---

<BaseLayout title={buildTitle("Manage events")} description="Add or remove events.">
  <section class="py-8 sm:py-12">
    <div class="flex items-center justify-between gap-4">
      <h1 class="font-display text-3xl font-semibold tracking-tight text-ink">
        Manage events
      </h1>
      <form method="POST">
        <input type="hidden" name="intent" value="signout" />
        <button
          type="submit"
          class="rounded-md border border-paper-dim px-3 py-1.5 text-sm text-ink-soft transition-colors hover:border-clay hover:text-clay"
        >
          Sign out
        </button>
      </form>
    </div>
    <p class="mt-2 text-sm text-ink-soft">Signed in as {user.email}.</p>

    {
      error && (
        <p class="mt-4 rounded-md border border-clay/40 bg-clay/5 px-3 py-2 text-sm text-clay">
          {error}
        </p>
      )
    }

    <!-- Add form -->
    <form method="POST" class="mt-8 space-y-4 rounded-lg border border-paper-dim p-5">
      <input type="hidden" name="intent" value="create" />
      <h2 class="font-display text-xl font-semibold text-ink">Add an event</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="title" class="block text-sm font-medium text-ink">Title</label>
          <input
            id="title"
            name="title"
            type="text"
            required
            class="mt-1 w-full rounded-md border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
          />
        </div>
        <div>
          <label for="event_date" class="block text-sm font-medium text-ink">Date</label>
          <input
            id="event_date"
            name="event_date"
            type="date"
            required
            class="mt-1 w-full rounded-md border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
          />
        </div>
      </div>
      <div>
        <label for="description" class="block text-sm font-medium text-ink">
          Description
        </label>
        <textarea
          id="description"
          name="description"
          rows="2"
          class="mt-1 w-full rounded-md border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
        ></textarea>
      </div>
      <button
        type="submit"
        class="rounded-md bg-clay px-4 py-2 font-medium text-paper transition-opacity hover:opacity-90"
      >
        Add event
      </button>
    </form>

    <!-- Existing events -->
    <ul class="mt-8 space-y-4">
      {
        events.map((event) => (
          <li class="flex items-start justify-between gap-4 rounded-lg border border-paper-dim p-4">
            <div>
              <p class="text-sm font-medium text-clay">
                {formatEventDate(event.event_date)}
              </p>
              <h3 class="mt-1 font-display text-lg font-semibold text-ink">
                {event.title}
              </h3>
              {event.description && (
                <p class="mt-1 text-sm text-ink-soft">{event.description}</p>
              )}
            </div>
            <form method="POST">
              <input type="hidden" name="intent" value="delete" />
              <input type="hidden" name="id" value={event.id} />
              <button
                type="submit"
                class="shrink-0 rounded-md border border-paper-dim px-3 py-1.5 text-sm text-ink-soft transition-colors hover:border-clay hover:text-clay"
              >
                Delete
              </button>
            </form>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
