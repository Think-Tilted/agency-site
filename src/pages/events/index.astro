---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildTitle } from "../../utils/seo";
import { createSupabaseServerClient } from "../../lib/supabase";
import { listEvents, formatEventDate } from "../../lib/events";

// Tier 2 page: rendered on-demand (SSR) so it always reflects the live database.
// Opt out of prerendering — this runs as a Netlify Function. (ADR-011)
export const prerender = false;

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const events = await listEvents(supabase);

// Is someone logged in? If so, surface a link to the editor.
const {
  data: { user },
} = await supabase.auth.getUser();
---

<BaseLayout
  title={buildTitle("Events")}
  description="Upcoming events, served live from the database."
>
  <section class="py-8 sm:py-12">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h1 class="font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
          Events
        </h1>
        <p class="mt-3 max-w-[60ch] text-lg text-ink-soft">
          This page is rendered on demand and pulls live from Supabase — edit the
          data and it shows up here immediately.
        </p>
      </div>
      <a
        href={user ? "/admin/events" : "/login"}
        class="shrink-0 rounded-md border border-paper-dim px-3 py-1.5 text-sm text-ink-soft transition-colors hover:border-clay hover:text-clay"
      >
        {user ? "Manage events" : "Admin login"}
      </a>
    </div>

    {
      events.length === 0 ? (
        <p class="mt-10 text-ink-soft">No events scheduled yet.</p>
      ) : (
        <ul class="mt-10 space-y-5">
          {events.map((event) => (
            <li class="rounded-lg border border-paper-dim p-5">
              <p class="text-sm font-medium text-clay">
                {formatEventDate(event.event_date)}
              </p>
              <h2 class="mt-1 font-display text-2xl font-semibold text-ink">
                {event.title}
              </h2>
              {event.description && (
                <p class="mt-2 max-w-[65ch] text-ink-soft">{event.description}</p>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
