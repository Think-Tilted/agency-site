---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildTitle } from "../utils/seo";
---

<BaseLayout
  title={buildTitle("Page not found")}
  description="The page you requested could not be found."
>

  <section class="py-16 text-center sm:py-24">
    <p class="font-display text-6xl font-semibold leading-none text-clay">404</p>
    <h1 class="mt-2 font-display text-3xl font-semibold text-ink">Page not found</h1>
    <p class="mt-3 text-lg text-ink-soft">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a href="/" class="btn-primary mt-8">Back to home</a>

  </section>
</BaseLayout>
