---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildTitle } from "../../utils/seo";
import { projects } from "../../data/projects";

export const getStaticPaths = (() => {
  return projects.map((project, index) => ({
    params: { slug: project.slug },
    props: { project, index },
  }));
}) satisfies GetStaticPaths;

const { project, index } = Astro.props;

// Index access is `Project | undefined` under `noUncheckedIndexedAccess`
// (strictest), so the compiler forces us to handle the wrap-around case.
const nextProject = projects[(index + 1) % projects.length];
---

<BaseLayout title={buildTitle(project.name)} description={project.summary}>
  <article class="py-8 sm:py-12">
    <a href="/work" class="text-sm text-ink-soft transition-colors hover:text-clay">
      ← Back to work
    </a>
    <h1
      class="mt-6 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl"
    >
      {project.name}
    </h1>
    <p class="mt-2 text-sm uppercase tracking-[0.14em] text-clay">
      {project.type} &middot; {project.year}
    </p>
    <p class="mt-6 max-w-[60ch] text-lg text-ink-soft">{project.summary}</p>

    {
      nextProject && nextProject.slug !== project.slug && (
        <a
          href={`/work/${nextProject.slug}`}
          class="mt-10 inline-block text-sm text-ink-soft transition-colors hover:text-clay"
        >
          Next project: <span class="text-clay">{nextProject.name}</span> →
        </a>
      )
    }
  </article>
</BaseLayout>
