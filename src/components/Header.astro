---
const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/work", label: "Work" },
  { href: "/events", label: "Events" },
  { href: "/contact", label: "Contact" },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="border-b border-paper-dim">
  <div
    class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4"
  >
    <a href="/" class="font-display text-xl font-semibold tracking-tight text-ink">
      Studio
    </a>
    <div class="flex items-center gap-5 sm:gap-7">
      <nav class="flex gap-5 sm:gap-7">
        {
          links.map((link) => (
            <a
              href={link.href}
              class:list={[
                "text-sm transition-colors hover:text-clay",
                isActive(link.href) ? "text-clay" : "text-ink-soft",
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="rounded-md border border-paper-dim p-1.5 text-ink-soft transition-colors hover:border-clay hover:text-clay"
      >
        <!-- Sun (shown in dark mode) -->
        <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <!-- Moon (shown in light mode) -->
        <svg class="block h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>

