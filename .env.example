# Copy to .env for local dev. Set the real values in Netlify's UI for production.

# Absolute site origin used to build canonical URLs (PRE-004 step 7).
PUBLIC_SITE_URL=https://agency-tka.netlify.app

# Supabase — Tier 2 only (PRE-005 / ADR-011). Both are public/anon-safe; Row
# Level Security enforces what the anon key can actually do. Find these in the
# Supabase dashboard (Project Settings -> API) or via `supabase projects api-keys`.
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
